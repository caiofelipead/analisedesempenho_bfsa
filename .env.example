# Supabase - Obtenha em: https://supabase.com/dashboard → Settings → API
REACT_APP_SUPABASE_URL=https://SEU-PROJETO.supabase.co
REACT_APP_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Google Sheets privada (opcional - sem isso usa a URL pública)
# URL do backend FastAPI que faz proxy para a planilha privada
REACT_APP_SHEETS_API_URL=http://localhost:8000

# Backend: ID da planilha Google (o ID que aparece na URL da planilha)
# Ex: https://docs.google.com/spreadsheets/d/ESTE_ID_AQUI/edit
GOOGLE_SPREADSHEET_ID=seu-spreadsheet-id-aqui

# Backend: Credenciais da Service Account (use UM dos dois)
# Opção 1: JSON inline (recomendado para deploy)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Opção 2: Caminho para o arquivo JSON
# GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json
